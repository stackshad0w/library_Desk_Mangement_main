# ── Turso (libSQL) ───────────────────────────────────────────────
# Create a database:  turso db create swami-abhyasika
# Get the URL:         turso db show swami-abhyasika --url
# Create a token:       turso db tokens create swami-abhyasika
TURSO_DATABASE_URL=libsql://swami-abhyasika-yourorg.turso.io
TURSO_AUTH_TOKEN=

# Leave both blank for local dev — falls back to a local file DB at
# data/app.db automatically (see lib/db.js), so `vercel dev` works with
# zero cloud setup.

# ── Auth ─────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=24h

# Used only by `npm run seed`
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# ── Cloudinary ───────────────────────────────────────────────────
# Dashboard → Settings → API Keys: https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional — puts every uploaded photo in this folder in your Cloudinary account
CLOUDINARY_FOLDER=swami-abhyasika

# If these three Cloudinary vars are left blank, photo uploads silently keep
# working the old way (base64 inline in the database) — nothing breaks,
# you just don't get the storage/bandwidth benefit until you set them.
